# This file documents variable names only. Never place real credentials here.
DJANGO_PRODUCTION=False
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_BEHIND_HTTPS_PROXY=False
DJANGO_HSTS_SECONDS=31536000
DJANGO_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_HSTS_PRELOAD=False

# Required when DJANGO_PRODUCTION=True because account email verification is mandatory.
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=True
DJANGO_DEFAULT_FROM_EMAIL=no-reply@example.com

# Optional OAuth providers. Configure matching HTTPS callback URLs first.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
KAKAO_OAUTH_CLIENT_ID=
KAKAO_OAUTH_CLIENT_SECRET=
NAVER_OAUTH_CLIENT_ID=
NAVER_OAUTH_CLIENT_SECRET=

# Optional public contact information. Leave blank to omit it from API/page output.
PORTFOLIO_CONTACT_EMAIL=
PORTFOLIO_INSTAGRAM_HANDLE=
PORTFOLIO_INSTAGRAM_URL=
PORTFOLIO_NAVER_BLOG_HANDLE=
PORTFOLIO_NAVER_BLOG_URL=
PORTFOLIO_KAKAO_OPEN_CHAT_HANDLE=
PORTFOLIO_KAKAO_OPEN_CHAT_URL=
